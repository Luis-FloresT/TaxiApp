PORT=3000
NODE_ENV=development

# In production set this to your frontend URL, for example:
# CORS_ORIGIN=https://panel.tudominio.com
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
ENABLE_SIMULATOR=true

DB_HOST=localhost
DB_PORT=5432
DB_NAME=taxi_whatsapp
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Optional for production providers that give one connection string:
# DATABASE_URL=postgresql://user:password@host:5432/database
# Railway can provide both. The backend prefers DATABASE_PUBLIC_URL when present.
# DATABASE_PUBLIC_URL=postgresql://user:password@host.proxy.rlwy.net:12345/database

REDIS_HOST=localhost
REDIS_PORT=6379
# Optional for production providers:
# REDIS_URL=redis://default:password@host:6379

# Keep pending while working in local simulation mode.
WA_PHONE_ID=pending
WA_ACCESS_TOKEN=pending
WA_VERIFY_TOKEN=local_verify_token

# Optional multi-line mode for one station with several WhatsApp numbers.
# If omitted, the backend uses WA_PHONE_ID as "Linea principal".
# WA_NUMBERS_JSON=[{"label":"Linea 1","phoneNumberId":"111111111111111","displayPhone":"593999000001"},{"label":"Linea 2","phoneNumberId":"222222222222222","displayPhone":"593999000002"}]

JWT_SECRET=change_this_in_production
JWT_EXPIRES=8h

# Automatically delete customer chats that never took a ride after this many days.
# Only pending customer chats without assigned driver are removed.
CUSTOMER_AUTO_CLEANUP_ENABLED=true
CUSTOMER_NO_RIDE_RETENTION_DAYS=7
